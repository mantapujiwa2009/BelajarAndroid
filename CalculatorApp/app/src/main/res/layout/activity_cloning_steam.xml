<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CloningSteam"
    android:background="#292C33">

    <TextView
        android:id="@+id/txtHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SIGN IN"
        android:textColor="#DFE2E9"
        android:textSize="40sp"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintEnd_toEndOf="@id/main"
        app:layout_constraintTop_toTopOf="@id/main"
        android:layout_marginTop="50dp"/>

    <TextView
        android:id="@+id/txtName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STEAM ACCOUNT NAME"
        android:textSize="15sp"
        android:textColor="#DFE2E9"
        app:layout_constraintTop_toBottomOf="@id/txtHeader"
        app:layout_constraintEnd_toEndOf="@id/txtHeader"
        android:layout_marginEnd="80dp"
        android:layout_marginTop="30dp" />
    
    <EditText
        android:id="@+id/edName"
        android:layout_width="350dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/txtName"
        app:layout_constraintStart_toStartOf="@id/txtName"
        android:layout_marginTop="8dp"
        android:background="#202126"/>

    <TextView
        android:id="@+id/txtPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STEAM ACCOUNT NAME"
        android:textSize="15sp"
        android:textColor="#DFE2E9"
        app:layout_constraintTop_toBottomOf="@id/edName"
        app:layout_constraintStart_toStartOf="@id/edName"
        android:layout_marginEnd="80dp"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/edPassword"
        android:layout_width="350dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/txtPassword"
        app:layout_constraintStart_toStartOf="@id/txtPassword"
        android:layout_marginTop="8dp"
        android:background="#202126"/>
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSign"
        android:layout_width="350dp"
        android:layout_height="50dp"
        app:layout_constraintStart_toStartOf="@id/edPassword"
        app:layout_constraintTop_toBottomOf="@id/edPassword"
        android:layout_marginTop="15dp"
        android:backgroundTint="#216CAD"
        android:text="Sign in"
        android:textColor="#9da0a8"
        android:textSize="20sp"
        app:cornerRadius="5dp"/>


    <TextView
        android:id="@+id/txtneed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I need help sign in"
        app:layout_constraintTop_toBottomOf="@id/btnSign"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:layout_marginEnd="150dp"
        android:textColor="#82868F"
        android:textSize="14sp"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/txtDontHave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dont have a steam account?"
        app:layout_constraintTop_toBottomOf="@id/txtneed"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:layout_marginEnd="92dp"
        android:textColor="#E0E3EA"
        android:textSize="18sp"
        android:layout_marginTop="60dp"/>

    <TextView
        android:id="@+id/txtInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="It's free and easy. Discover thousands of \nPc games to play with millions of new \nfriends"
        app:layout_constraintTop_toBottomOf="@id/txtDontHave"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:layout_marginEnd="61dp"
        android:textColor="#82868F"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginTop="25dp"/>

    <TextView
        android:id="@+id/txtLearn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Learn more about Steam"
        app:layout_constraintTop_toBottomOf="@id/txtInfo"
        app:layout_constraintEnd_toEndOf="@id/main"
        android:layout_marginEnd="118dp"
        android:textColor="#82868F"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginTop="25dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>